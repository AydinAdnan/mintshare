{
  "name": "file-sharing",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:signal\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace @fileshare/web",
    "dev:signal": "npm run dev --workspace @fileshare/signal",
    "build": "npm run build --workspaces"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
